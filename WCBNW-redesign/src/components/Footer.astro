---
const bookingUrl = 'https://whiskeycreekbeachnw.guestybookings.com/en/properties?city=Port+Angeles&country=United+States&minOccupancy=1';

const exploreLinks = [
  { label: 'Home', href: '/' },
  { label: 'Properties', href: '/properties' },
  { label: 'Experiences', href: '/experiences' },
  { label: 'About', href: '/about' },
];

const infoLinks = [
  { label: 'Contact', href: '/contact' },
  { label: 'Policies', href: '/policies' },
  { label: 'Book Now', href: bookingUrl, external: true },
];
---

<!-- Organic ridge divider -->
<div class="relative bg-cloud">
  <svg viewBox="0 0 1440 80" preserveAspectRatio="none" class="w-full block" style="margin-bottom: -1px;">
    <path d="M0,80 L0,50 Q120,20 280,35 Q440,50 600,25 Q760,0 920,30 Q1080,55 1240,20 Q1360,0 1440,15 L1440,80 Z" fill="#0f2318" />
  </svg>
</div>

<footer class="bg-forest">
  <div class="max-w-6xl mx-auto py-16 px-6">
    <!-- Four-column grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-8">

      <!-- Brand -->
      <div>
        <a href="/" class="font-display text-cloud text-2xl font-light tracking-wide-caps">
          Whiskey Creek Beach
        </a>
        <p class="mt-3 text-sage/60 text-sm font-display italic">
          Where the forest meets the sea
        </p>
        <p class="mt-5 text-stone/50 text-sm leading-relaxed font-body">
          1385 Whiskey Creek Beach Rd<br />
          Port Angeles, WA 98363
        </p>
      </div>

      <!-- Explore -->
      <div>
        <h3 class="text-driftwood font-body text-xs uppercase tracking-wider-caps mb-5">Explore</h3>
        <ul class="space-y-3">
          {exploreLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-stone/60 hover:text-cloud text-sm font-body transition-colors duration-300"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Info -->
      <div>
        <h3 class="text-driftwood font-body text-xs uppercase tracking-wider-caps mb-5">Info</h3>
        <ul class="space-y-3">
          {infoLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-stone/60 hover:text-cloud text-sm font-body transition-colors duration-300"
                {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-driftwood font-body text-xs uppercase tracking-wider-caps mb-5">Contact</h3>
        <ul class="space-y-3">
          <li>
            <a
              href="tel:+18447692322"
              class="text-stone/60 hover:text-cloud text-sm font-body transition-colors duration-300"
            >
              (844) 769-2322
            </a>
          </li>
          <li>
            <a
              href="mailto:whiskeycreekbeachnw@gmail.com"
              class="text-stone/60 hover:text-cloud text-sm font-body transition-colors duration-300 break-all"
            >
              whiskeycreekbeachnw@gmail.com
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-white/5 pt-8 mt-12 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-stone/30 text-xs font-body">
        &copy; 2026 Whiskey Creek Beach NW. All rights reserved.
      </p>
      <span class="text-stone/20 text-xs font-body site-version">v4.0.0</span>
    </div>
  </div>
</footer>
