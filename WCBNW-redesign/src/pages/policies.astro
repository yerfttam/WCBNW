---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Policies" transparentNav={true}>

  <!-- ═══════════════════ 1. HERO ═══════════════════ -->
  <section class="relative h-[35vh] overflow-hidden">
    <img
      src="/photos/outdoor/DSC_0397.jpg"
      alt="Whiskey Creek Beach coastline"
      loading="eager"
      decoding="async"
      class="absolute inset-0 w-full h-full object-cover"
    />

    <!-- Content anchored to bottom -->
    <div class="absolute bottom-0 left-0 right-0 pb-12 text-center">
      <p class="section-label text-white/80">POLICIES</p>
      <h1 class="font-display text-4xl md:text-5xl font-bold text-white drop-shadow-lg">Good to Know</h1>
    </div>
  </section>

  <!-- ═══════════════════ 2. POLICIES CONTENT ═══════════════════ -->
  <section class="py-24 px-6 bg-white">
    <div class="max-w-4xl mx-auto lg:grid lg:grid-cols-[220px_1fr] gap-12">

      <!-- Left — Sticky Jump Links (desktop only) -->
      <aside class="hidden lg:block">
        <nav class="sticky top-[96px]">
          <p class="text-xs uppercase tracking-wider-caps text-stone font-medium mb-4">Quick Links</p>
          <div class="flex flex-col gap-3">
            <a href="#booking" class="policy-nav-link text-sm text-stone hover:text-moss transition-colors" data-target="booking">Booking Policies</a>
            <a href="#cancellation" class="policy-nav-link text-sm text-stone hover:text-moss transition-colors" data-target="cancellation">Cancellation Policies</a>
            <a href="#pets" class="policy-nav-link text-sm text-stone hover:text-moss transition-colors" data-target="pets">Pet Policies</a>
          </div>
        </nav>
      </aside>

      <!-- Right — Policy Sections (accordion) -->
      <div class="space-y-0">

        <!-- ── Booking Policies ── -->
        <div id="booking" class="policy-section" data-open="true">
          <button type="button" class="policy-header flex items-center justify-between w-full cursor-pointer py-4 border-b border-fog group text-left">
            <div class="flex items-center">
              <span class="w-8 h-8 rounded-full bg-moss/10 flex items-center justify-center mr-4 shrink-0">
                <svg class="w-4 h-4 text-moss" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <rect x="3" y="4" width="18" height="18" rx="2" />
                  <line x1="16" y1="2" x2="16" y2="6" />
                  <line x1="8" y1="2" x2="8" y2="6" />
                  <line x1="3" y1="10" x2="21" y2="10" />
                </svg>
              </span>
              <h2 class="font-display text-xl font-bold text-midnight group-hover:text-moss transition-colors">Booking Policies</h2>
            </div>
            <svg class="policy-chevron w-5 h-5 text-stone transition-transform duration-300 shrink-0 ml-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <polyline points="6 9 12 15 18 9" />
            </svg>
          </button>
          <div class="policy-content overflow-hidden transition-all duration-300">
            <div class="py-6 text-stone leading-relaxed">
              <h3 class="font-medium text-midnight mb-3">Reservations</h3>
              <ul class="list-disc pl-5 space-y-2">
                <li>Reservations can be made online through our booking platform or by calling (844) 769-2322.</li>
                <li>A valid credit card is required to secure your reservation.</li>
                <li>Check-in time is 4:00 PM. Check-out time is 11:00 AM.</li>
                <li>Early check-in and late check-out may be available upon request, subject to availability.</li>
              </ul>

              <h3 class="font-medium text-midnight mt-6 mb-3">Rates &amp; Fees</h3>
              <ul class="list-disc pl-5 space-y-2">
                <li>Nightly rates vary by property and season.</li>
                <li>A cleaning fee applies to all reservations.</li>
                <li>Rates are subject to applicable taxes.</li>
                <li>Minimum stay requirements may apply during peak seasons and holidays.</li>
              </ul>

              <div class="bg-moss/5 border-l-4 border-moss p-4 rounded-r-lg mt-6">
                <p class="text-sm">For the best rates and availability, book directly through our website.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- ── Cancellation Policies ── -->
        <div id="cancellation" class="policy-section" data-open="true">
          <button type="button" class="policy-header flex items-center justify-between w-full cursor-pointer py-4 border-b border-fog group text-left">
            <div class="flex items-center">
              <span class="w-8 h-8 rounded-full bg-moss/10 flex items-center justify-center mr-4 shrink-0">
                <svg class="w-4 h-4 text-moss" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <circle cx="12" cy="12" r="10" />
                  <line x1="15" y1="9" x2="9" y2="15" />
                  <line x1="9" y1="9" x2="15" y2="15" />
                </svg>
              </span>
              <h2 class="font-display text-xl font-bold text-midnight group-hover:text-moss transition-colors">Cancellation Policies</h2>
            </div>
            <svg class="policy-chevron w-5 h-5 text-stone transition-transform duration-300 shrink-0 ml-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <polyline points="6 9 12 15 18 9" />
            </svg>
          </button>
          <div class="policy-content overflow-hidden transition-all duration-300">
            <div class="py-6 text-stone leading-relaxed">
              <h3 class="font-medium text-midnight mb-3">Standard Cancellation</h3>
              <ul class="list-disc pl-5 space-y-2">
                <li>Cancellations made 30 or more days before check-in receive a full refund.</li>
                <li>Cancellations made 14–29 days before check-in receive a 50% refund.</li>
                <li>Cancellations made less than 14 days before check-in are non-refundable.</li>
              </ul>

              <h3 class="font-medium text-midnight mt-6 mb-3">Modifications</h3>
              <ul class="list-disc pl-5 space-y-2">
                <li>Date changes are subject to availability and may result in rate adjustments.</li>
                <li>Please contact us as soon as possible if you need to modify your reservation.</li>
              </ul>

              <div class="bg-copper/5 border-l-4 border-copper p-4 rounded-r-lg mt-6">
                <p class="text-sm">We strongly recommend travel insurance for all reservations.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- ── Pet Policies ── -->
        <div id="pets" class="policy-section" data-open="true">
          <button type="button" class="policy-header flex items-center justify-between w-full cursor-pointer py-4 border-b border-fog group text-left">
            <div class="flex items-center">
              <span class="w-8 h-8 rounded-full bg-moss/10 flex items-center justify-center mr-4 shrink-0">
                <svg class="w-4 h-4 text-moss" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path d="M12 21c-1.5 0-3-1.5-3-3 0-2 3-4 3-4s3 2 3 4c0 1.5-1.5 3-3 3z" />
                  <circle cx="5" cy="10" r="2" />
                  <circle cx="19" cy="10" r="2" />
                  <circle cx="8" cy="5" r="2" />
                  <circle cx="16" cy="5" r="2" />
                </svg>
              </span>
              <h2 class="font-display text-xl font-bold text-midnight group-hover:text-moss transition-colors">Pet Policies</h2>
            </div>
            <svg class="policy-chevron w-5 h-5 text-stone transition-transform duration-300 shrink-0 ml-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <polyline points="6 9 12 15 18 9" />
            </svg>
          </button>
          <div class="policy-content overflow-hidden transition-all duration-300">
            <div class="py-6 text-stone leading-relaxed">
              <h3 class="font-medium text-midnight mb-3">Pet-Friendly Properties</h3>
              <ul class="list-disc pl-5 space-y-2">
                <li>Select properties welcome pets. Please check individual property listings for pet-friendly status.</li>
                <li>A pet fee may apply per pet, per stay.</li>
                <li>Maximum of 2 pets per property unless otherwise specified.</li>
              </ul>

              <h3 class="font-medium text-midnight mt-6 mb-3">Pet Rules</h3>
              <ul class="list-disc pl-5 space-y-2">
                <li>Pets must be kept on a leash in common areas.</li>
                <li>Owners are responsible for cleaning up after their pets.</li>
                <li>Pets should not be left unattended in the property.</li>
                <li>Any damage caused by pets will be charged to the guest.</li>
              </ul>

              <div class="bg-moss/5 border-l-4 border-moss p-4 rounded-r-lg mt-6">
                <p class="text-sm">Not sure if your property is pet-friendly? Contact us and we'll help you find the perfect pet-friendly stay.</p>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════ 3. BOTTOM CTA ═══════════════════ -->
  <section class="py-16 bg-drift text-center">
    <h2 class="font-display text-2xl text-midnight mb-4">Have questions about our policies?</h2>
    <p class="text-stone mb-8">We're happy to help clarify anything before you book.</p>
    <div class="flex gap-4 justify-center flex-wrap px-6">
      <a href="/contact" class="btn-primary">Contact Us</a>
      <a href="/properties" class="btn-secondary">Browse Properties</a>
    </div>
  </section>

</BaseLayout>

<script>
  // ── Accordion logic ──
  function initPolicyAccordions() {
    const sections = document.querySelectorAll<HTMLDivElement>('.policy-section');

    sections.forEach((section) => {
      const header = section.querySelector<HTMLButtonElement>('.policy-header');
      const content = section.querySelector<HTMLDivElement>('.policy-content');
      const chevron = section.querySelector<SVGElement>('.policy-chevron');

      if (!header || !content || !chevron) return;

      // Initialize: all sections start open
      const isOpen = section.dataset.open === 'true';
      if (isOpen) {
        content.style.maxHeight = content.scrollHeight + 'px';
        chevron.style.transform = 'rotate(180deg)';
      } else {
        content.style.maxHeight = '0px';
        chevron.style.transform = 'rotate(0deg)';
      }

      header.addEventListener('click', () => {
        const currentlyOpen = section.dataset.open === 'true';

        if (currentlyOpen) {
          // Close
          content.style.maxHeight = content.scrollHeight + 'px';
          // Force reflow
          content.offsetHeight;
          content.style.maxHeight = '0px';
          chevron.style.transform = 'rotate(0deg)';
          section.dataset.open = 'false';
        } else {
          // Open
          content.style.maxHeight = content.scrollHeight + 'px';
          chevron.style.transform = 'rotate(180deg)';
          section.dataset.open = 'true';

          // Remove max-height after transition so content can reflow
          content.addEventListener('transitionend', function handler() {
            if (section.dataset.open === 'true') {
              content.style.maxHeight = 'none';
            }
            content.removeEventListener('transitionend', handler);
          });
        }
      });
    });

    // ── Jump link handling ──
    const navLinks = document.querySelectorAll<HTMLAnchorElement>('.policy-nav-link');

    navLinks.forEach((link) => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const targetId = link.dataset.target;
        if (!targetId) return;

        const targetSection = document.getElementById(targetId);
        if (!targetSection) return;

        // Ensure section is open
        const content = targetSection.querySelector<HTMLDivElement>('.policy-content');
        const chevron = targetSection.querySelector<SVGElement>('.policy-chevron');

        if (targetSection.dataset.open !== 'true' && content && chevron) {
          content.style.maxHeight = content.scrollHeight + 'px';
          chevron.style.transform = 'rotate(180deg)';
          targetSection.dataset.open = 'true';

          content.addEventListener('transitionend', function handler() {
            if (targetSection.dataset.open === 'true') {
              content.style.maxHeight = 'none';
            }
            content.removeEventListener('transitionend', handler);
          });
        }

        // Scroll to section
        targetSection.scrollIntoView({ behavior: 'smooth', block: 'start' });

        // Update active state
        updateActiveLink(targetId);
      });
    });

    // Update active nav link based on scroll position
    function updateActiveLink(activeId: string) {
      navLinks.forEach((link) => {
        if (link.dataset.target === activeId) {
          link.classList.add('text-moss', 'font-medium');
          link.classList.remove('text-stone');
        } else {
          link.classList.remove('text-moss', 'font-medium');
          link.classList.add('text-stone');
        }
      });
    }

    // Scroll spy for nav links
    const observerOptions = {
      rootMargin: '-100px 0px -60% 0px',
      threshold: 0,
    };

    const scrollObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          updateActiveLink(entry.target.id);
        }
      });
    }, observerOptions);

    sections.forEach((section) => {
      scrollObserver.observe(section);
    });

    // ── Handle URL hash on load ──
    const hash = window.location.hash.replace('#', '');
    if (hash) {
      const targetSection = document.getElementById(hash);
      if (targetSection) {
        // Ensure section is open
        const content = targetSection.querySelector<HTMLDivElement>('.policy-content');
        const chevron = targetSection.querySelector<SVGElement>('.policy-chevron');

        if (targetSection.dataset.open !== 'true' && content && chevron) {
          content.style.maxHeight = content.scrollHeight + 'px';
          chevron.style.transform = 'rotate(180deg)';
          targetSection.dataset.open = 'true';
        }

        // Small delay to let page render, then scroll
        setTimeout(() => {
          targetSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
          updateActiveLink(hash);
        }, 100);
      }
    }
  }

  // Run on DOM ready and after Astro page transitions
  document.addEventListener('DOMContentLoaded', initPolicyAccordions);
  document.addEventListener('astro:page-load', initPolicyAccordions);
</script>
