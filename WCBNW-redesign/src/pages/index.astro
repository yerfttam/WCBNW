---
import BaseLayout from '../layouts/BaseLayout.astro';
import PropertyCard from '../components/PropertyCard.astro';
import listingsData from '../data/listings.json';
import experiencesData from '../data/experiences.json';

// Build flat listing list for filtering
const allListings = listingsData.categories.flatMap(cat =>
  cat.listings.map(l => ({ ...l, categorySlug: cat.slug, categoryName: cat.name }))
);

function getExperienceListings(filter: any) {
  return allListings.filter(listing => {
    if (filter.categories && !filter.categories.includes(listing.categorySlug)) return false;
    if (filter.maxGuests && listing.accommodates > filter.maxGuests) return false;
    if (filter.minGuests && listing.accommodates < filter.minGuests) return false;
    if (filter.amenity && !listing.amenities.includes(filter.amenity)) return false;
    return true;
  });
}

const categories = listingsData.categories;

// Wizard data — mapped at build time for counts
const wizardChoices = [
  {
    key: 'stillness',
    title: 'Stillness',
    subtitle: 'Quiet waters, gentle mornings',
    photo: '/photos/codfish/DSC_6006-HDR.jpg',
    options: [
      { label: 'With Someone', slug: 'romantic-escape', subtitle: 'Fireside evenings for two', count: getExperienceListings({ maxGuests: 4, categories: ['beach-front-cabins', 'cottages'] }).length },
      { label: 'Just Me', slug: 'solo-retreat', subtitle: 'Unplug, reset, breathe', count: getExperienceListings({ maxGuests: 3, categories: ['a-frames'] }).length },
    ],
  },
  {
    key: 'together',
    title: 'Together',
    subtitle: 'Laughter, sand castles, shared sunsets',
    photo: '/photos/outdoor/DSC_0020.JPG',
    options: [
      { label: 'The Whole Crew', slug: 'family-adventure', subtitle: 'Room for everyone', count: getExperienceListings({ minGuests: 4, categories: ['beach-front-cabins', 'cottages'] }).length },
      { label: 'Right on the Water', slug: 'beachfront-living', subtitle: 'Steps from the shore', count: getExperienceListings({ categories: ['beach-front-cabins'] }).length },
    ],
  },
  {
    key: 'wild',
    title: 'Wild',
    subtitle: 'Campfires, paw prints, open sky',
    photo: '/photos/outdoor/DSC_0335.jpg',
    options: [
      { label: 'Under the Stars', slug: 'budget-friendly', subtitle: 'All the beauty, easy on the wallet', count: getExperienceListings({ categories: ['tent-sites', 'rv-sites'] }).length },
      { label: 'With My Best Friend', slug: 'pet-friendly', subtitle: 'Your dog deserves this too', count: getExperienceListings({ amenity: 'Pets allowed' }).length },
    ],
  },
];
---

<BaseLayout title="Home" transparentNav={true}>

  <!-- ═══════════════════════════════════════════════════════
       1. HERO — Immersive full-screen with fog + wizard
       ═══════════════════════════════════════════════════════ -->
  <section class="relative min-h-screen overflow-hidden bg-forest">
    <!-- Background photo -->
    <img
      src="/photos/outdoor/DSC_0020.JPG"
      alt="Whiskey Creek Beach shoreline at golden hour"
      loading="eager"
      decoding="async"
      class="absolute inset-0 w-full h-full object-cover animate-slow-zoom"
    />

    <!-- Deep gradient overlay -->
    <div class="absolute inset-0 bg-gradient-to-b from-forest/80 via-forest/30 to-forest/80"></div>

    <!-- Fog layers -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="fog-layer fog-layer-1 animate-fog-1 opacity-60" style="top: 20%;"></div>
      <div class="fog-layer fog-layer-2 animate-fog-2 opacity-40" style="top: 50%;"></div>
      <div class="fog-layer fog-layer-3 animate-fog-3 opacity-30 animate-breathe" style="top: 70%;"></div>
    </div>

    <!-- Content -->
    <div class="relative z-10 flex flex-col items-center justify-center min-h-screen px-6 py-32">

      <!-- Branding -->
      <p class="text-[11px] uppercase tracking-wider-caps font-body font-medium text-white/40 mb-6">
        Port Angeles, Washington
      </p>
      <h1 class="font-display text-5xl md:text-7xl lg:text-8xl font-light text-white text-center leading-[0.95] mb-4">
        Find Your Coast
      </h1>
      <p class="text-lg md:text-xl text-white/50 font-body font-light mb-16 max-w-lg text-center" style="letter-spacing: 0.01em;">
        32 unique stays where the forest meets the sea.
      </p>

      <!-- ── WIZARD ── -->
      <div id="wizard" class="wizard-container w-full max-w-5xl">

        <!-- Step 1: Three portals -->
        <div id="wizard-step-1" class="wizard-step" data-visible="true">
          <p class="text-center text-white/40 text-xs uppercase tracking-wider-caps font-body mb-6">
            What draws you to the coast?
          </p>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-5">
            {wizardChoices.map((choice) => (
              <button
                class="wizard-portal group rounded-2xl overflow-hidden aspect-[3/4] md:aspect-[2/3] relative text-left"
                data-choice={choice.key}
                aria-label={`Choose ${choice.title}`}
              >
                <img
                  src={choice.photo}
                  alt={choice.title}
                  loading="eager"
                  decoding="async"
                  class="absolute inset-0 w-full h-full object-cover"
                />
                <div class="absolute inset-0 z-10 flex flex-col justify-end p-6 md:p-8">
                  <span class="font-display text-4xl md:text-5xl font-light text-white mb-2">
                    {choice.title}
                  </span>
                  <span class="text-white/50 text-sm font-body font-light">
                    {choice.subtitle}
                  </span>
                </div>
              </button>
            ))}
          </div>

          <!-- Skip wizard link -->
          <div class="mt-10 flex flex-col items-center gap-3">
            <span class="text-white/20 text-[10px] uppercase tracking-wider-caps font-body">or</span>
            <a
              href="/properties"
              class="inline-flex items-center gap-2 text-white/40 hover:text-white/70 text-sm font-body transition-colors duration-300"
            >
              I know what I want
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />
              </svg>
            </a>
          </div>
        </div>

        <!-- Step 2: Refinement (rendered per choice, toggled by JS) -->
        {wizardChoices.map((choice) => (
          <div
            id={`wizard-step-2-${choice.key}`}
            class="wizard-step"
            data-visible="false"
          >
            <!-- Back button -->
            <div class="flex justify-center mb-6">
              <button
                class="wizard-back inline-flex items-center gap-2 text-white/40 hover:text-white/70 text-sm font-body transition-colors duration-300"
                aria-label="Go back"
              >
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 15.75L3 12m0 0l3.75-3.75M3 12h18" />
                </svg>
                Start over
              </button>
            </div>

            <p class="text-center text-white/40 text-xs uppercase tracking-wider-caps font-body mb-6">
              Tell us more
            </p>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-5 max-w-3xl mx-auto">
              {choice.options.map((opt) => (
                <a
                  href={`/experiences#${opt.slug}`}
                  class="group relative rounded-2xl overflow-hidden bg-white/5 backdrop-blur-sm border border-white/10 hover:border-white/25 hover:bg-white/10 transition-all duration-500 p-8 md:p-10 text-center"
                >
                  <span class="font-display text-3xl md:text-4xl font-light text-white block mb-3">
                    {opt.label}
                  </span>
                  <span class="text-white/40 text-sm font-body block mb-4">
                    {opt.subtitle}
                  </span>
                  <span class="text-ember text-xs font-body font-medium uppercase tracking-wide-caps">
                    {opt.count} {opt.count === 1 ? 'property' : 'properties'}
                  </span>
                  <!-- Hover arrow -->
                  <div class="mt-6 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-white/40 mx-auto" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />
                    </svg>
                  </div>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 flex flex-col items-center gap-2">
      <span class="text-white/20 text-[10px] uppercase tracking-wider-caps font-body">Scroll</span>
      <div class="w-[1px] h-8 bg-gradient-to-b from-white/20 to-transparent animate-breathe"></div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       ORGANIC DIVIDER — Mountain ridge
       ═══════════════════════════════════════════════════════ -->
  <div class="relative bg-forest">
    <svg viewBox="0 0 1440 100" preserveAspectRatio="none" class="w-full block" style="margin-bottom: -1px;">
      <path d="M0,100 L0,60 Q180,15 360,40 Q540,65 720,25 Q900,0 1080,35 Q1260,60 1440,20 L1440,100 Z" class="fill-cloud" />
    </svg>
  </div>

  <!-- ═══════════════════════════════════════════════════════
       2. EXPLORE BY TYPE — Category cards with photos
       ═══════════════════════════════════════════════════════ -->
  <section class="fade-section py-20 md:py-28 px-6 bg-cloud">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14">
        <p class="section-label">Explore</p>
        <h2 class="section-title mt-3 mb-5">Pick Your Style</h2>
        <p class="text-stone text-lg max-w-xl mx-auto font-light">
          From beachfront cabins to tent sites under the stars — every stay has its own personality.
        </p>
      </div>

      <!-- Category cards -->
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-3 md:gap-4">
        {categories.map((cat) => {
          const photo = cat.listings[0]?.photos[0]?.thumbnail;
          return (
            <a
              href={`/properties#${cat.slug}`}
              class="stagger-child group relative rounded-xl overflow-hidden aspect-[3/4] block"
            >
              <img
                src={photo}
                alt={cat.name}
                loading="lazy"
                decoding="async"
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
              />
              <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-forest/90"></div>
              <div class="absolute bottom-0 left-0 right-0 p-4 text-center">
                <span class="font-display text-base md:text-lg font-normal text-white block mb-1">
                  {cat.name}
                </span>
                <span class="text-white/40 text-xs font-body">
                  {cat.listings.length} {cat.listings.length === 1 ? 'stay' : 'stays'}
                </span>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       3. THE SETTING — Asymmetric photo + narrative
       ═══════════════════════════════════════════════════════ -->
  <section class="fade-section py-20 md:py-28 px-6 bg-mist">
    <div class="max-w-6xl mx-auto">
      <div class="grid lg:grid-cols-12 gap-8 lg:gap-16 items-center">
        <!-- Left: Photo (takes 7 columns for asymmetry) -->
        <div class="lg:col-span-7">
          <div class="relative">
            <img
              src="/photos/outdoor/DSC_0030.JPG"
              alt="View of the Strait of Juan de Fuca shoreline"
              loading="lazy"
              decoding="async"
              class="rounded-2xl shadow-2xl aspect-[4/5] w-full object-cover"
            />
            <!-- Floating accent photo -->
            <img
              src="/photos/outdoor/DSC_0560.JPG"
              alt="Beach detail"
              loading="lazy"
              decoding="async"
              class="hidden md:block absolute -bottom-8 -right-8 w-48 h-48 rounded-2xl shadow-xl object-cover border-4 border-mist"
            />
          </div>
        </div>

        <!-- Right: Copy (takes 5 columns) -->
        <div class="lg:col-span-5">
          <p class="section-label">The Setting</p>
          <h2 class="font-display text-4xl md:text-5xl font-light text-forest mt-3 mb-6 leading-tight">
            On the shores of the Strait of Juan&nbsp;de&nbsp;Fuca
          </h2>
          <p class="text-stone text-lg leading-relaxed mb-10 font-light">
            Where the Olympic Mountains meet the Pacific, a string of handcrafted cabins, cottages,
            and hideaways wait along a pristine stretch of beach. This isn't a resort — it's a place
            that feels like it's yours.
          </p>

          <!-- Stats row -->
          <div class="flex gap-10">
            <div>
              <span class="font-display text-4xl font-light text-ember block">32</span>
              <span class="text-stone text-xs uppercase tracking-wider-caps font-body mt-1 block">Unique Stays</span>
            </div>
            <div>
              <span class="font-display text-4xl font-light text-ember block">6</span>
              <span class="text-stone text-xs uppercase tracking-wider-caps font-body mt-1 block">Property Styles</span>
            </div>
            <div>
              <span class="font-display text-4xl font-light text-ember block italic">Steps</span>
              <span class="text-stone text-xs uppercase tracking-wider-caps font-body mt-1 block">From the Beach</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       4. THE PLACE — Deep, atmospheric
       ═══════════════════════════════════════════════════════ -->
  <div class="relative bg-mist">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none" class="w-full block" style="margin-bottom: -1px;">
      <path d="M0,80 L0,55 Q240,10 480,40 Q720,70 960,20 Q1200,0 1440,35 L1440,80 Z" class="fill-forest" />
    </svg>
  </div>

  <section class="fade-section py-20 md:py-28 px-6 bg-forest text-white">
    <div class="max-w-6xl mx-auto grid lg:grid-cols-12 gap-8 lg:gap-16 items-center">
      <!-- Left: Copy (5 columns) -->
      <div class="lg:col-span-5">
        <p class="section-label text-sage/60">The Place</p>
        <h2 class="font-display text-4xl md:text-5xl font-light text-cloud mt-3 mb-6 leading-tight">
          Port Angeles, Washington
        </h2>
        <p class="text-driftwood/70 text-lg leading-relaxed mb-10 font-light">
          Nestled on the northern edge of the Olympic Peninsula, Whiskey Creek Beach sits between
          the wild beauty of Olympic National Park and the serene waters of the Strait of Juan de Fuca.
        </p>

        <!-- Feature items -->
        <div class="space-y-5">
          <div class="flex gap-4 items-center">
            <div class="w-10 h-10 rounded-full bg-fern/20 flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-sage" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
              </svg>
            </div>
            <span class="text-driftwood/60 text-sm font-body">10 minutes to downtown Port Angeles</span>
          </div>

          <div class="flex gap-4 items-center">
            <div class="w-10 h-10 rounded-full bg-fern/20 flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-sage" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 7.5h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008z" />
              </svg>
            </div>
            <span class="text-driftwood/60 text-sm font-body">30 minutes to Hurricane Ridge</span>
          </div>

          <div class="flex gap-4 items-center">
            <div class="w-10 h-10 rounded-full bg-fern/20 flex items-center justify-center flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-sage" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />
              </svg>
            </div>
            <span class="text-driftwood/60 text-sm font-body">Gateway to Olympic National Park</span>
          </div>
        </div>
      </div>

      <!-- Right: Aerial photo (7 columns) -->
      <div class="lg:col-span-7">
        <img
          src="/images/properties/DJI_0043-aerial.jpg"
          alt="Aerial view of Whiskey Creek Beach"
          loading="lazy"
          decoding="async"
          class="rounded-2xl shadow-2xl object-cover aspect-[4/3] w-full"
        />
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       ORGANIC DIVIDER
       ═══════════════════════════════════════════════════════ -->
  <div class="relative bg-forest">
    <svg viewBox="0 0 1440 80" preserveAspectRatio="none" class="w-full block" style="margin-bottom: -1px;">
      <path d="M0,80 L0,40 Q360,0 720,50 Q1080,80 1440,25 L1440,80 Z" class="fill-cloud" />
    </svg>
  </div>

  <!-- ═══════════════════════════════════════════════════════
       5. CTA BAND — Warm, inviting
       ═══════════════════════════════════════════════════════ -->
  <section class="fade-section py-24 md:py-32 relative bg-cloud overflow-hidden">
    <!-- Subtle texture -->
    <img
      src="/images/bkgds/bkgd1.jpg"
      alt=""
      loading="lazy"
      decoding="async"
      class="absolute inset-0 w-full h-full object-cover opacity-[0.04]"
      aria-hidden="true"
    />

    <!-- Content -->
    <div class="relative z-10 text-center max-w-2xl mx-auto px-6">
      <p class="section-label mb-3">Not sure yet?</p>
      <h2 class="font-display text-4xl md:text-5xl font-light text-forest mb-6">
        We'll help you find the&nbsp;one
      </h2>
      <p class="text-stone text-lg font-light mb-10">
        Drop us a line and tell us what you're looking for — we'll point you to the perfect stay.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a href="/properties" class="btn-primary">Browse All Properties</a>
        <a href="/contact" class="btn-secondary">Contact Us</a>
      </div>
    </div>
  </section>

</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const step1 = document.getElementById('wizard-step-1');
    const portalBtns = document.querySelectorAll('.wizard-portal');
    const backBtns = document.querySelectorAll('.wizard-back');

    // Step 1 → Step 2
    portalBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const choice = btn.getAttribute('data-choice');
        const step2 = document.getElementById(`wizard-step-2-${choice}`);
        if (!step1 || !step2) return;

        step1.setAttribute('data-visible', 'false');
        step2.setAttribute('data-visible', 'true');
      });
    });

    // Step 2 → Back to Step 1
    backBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        // Hide all step 2s
        document.querySelectorAll('[id^="wizard-step-2-"]').forEach((el) => {
          el.setAttribute('data-visible', 'false');
        });
        // Show step 1
        if (step1) step1.setAttribute('data-visible', 'true');
      });
    });
  });
</script>
