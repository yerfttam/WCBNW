---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About Us" transparentNav={true}>

  <!-- ═══════════════════ 1. HERO ═══════════════════ -->
  <section class="relative h-[50vh] overflow-hidden">
    <img
      src="/photos/outdoor/DSC_0318.JPG"
      alt="Whiskey Creek Beach coastline"
      loading="eager"
      decoding="async"
      class="absolute inset-0 w-full h-full object-cover"
    />

    <!-- Content anchored to bottom -->
    <div class="absolute bottom-0 left-0 right-0 pb-16 text-center">
      <p class="section-label text-white/80">ABOUT US</p>
      <h1 class="font-display text-5xl font-bold text-white drop-shadow-lg">Our Story</h1>
    </div>
  </section>

  <!-- ═══════════════════ 2. THE BEGINNING ═══════════════════ -->
  <section class="fade-section py-24 px-6 bg-white">
    <div class="max-w-6xl mx-auto grid lg:grid-cols-2 gap-16 items-center">
      <!-- Left: Copy -->
      <div>
        <p class="section-label">HOW IT STARTED</p>
        <h2 class="section-title mt-3 mb-6">A Place Worth Sharing</h2>
        <p class="text-stone text-lg leading-relaxed mb-6">
          What began as a family retreat on the shores of the Strait of Juan de Fuca grew into
          something we couldn't keep to ourselves. The rugged beauty of this coastline — the
          driftwood-lined beaches, the eagles overhead, the mountains rising from the water —
          deserved to be experienced by others.
        </p>
        <p class="text-stone text-lg leading-relaxed">
          So we opened our doors. One cabin became two, then three, then a collection of unique
          stays, each with its own character but all sharing the same stunning setting.
        </p>
      </div>

      <!-- Right: Photo -->
      <div>
        <img
          src="/images/about/bonfire.jpg"
          alt="Bonfire on Whiskey Creek Beach"
          loading="lazy"
          decoding="async"
          class="rounded-lg shadow-xl aspect-[4/5] w-full object-cover"
        />
      </div>
    </div>
  </section>

  <!-- ═══════════════════ 3. THE VISION ═══════════════════ -->
  <section class="fade-section py-24 px-6 bg-drift">
    <div class="max-w-6xl mx-auto grid lg:grid-cols-2 gap-16 items-center">
      <!-- Left: Photo (reversed order on desktop) -->
      <div>
        <img
          src="/images/about/hiking.jpg"
          alt="Hiking on the Olympic Peninsula"
          loading="lazy"
          decoding="async"
          class="rounded-lg shadow-xl aspect-[4/5] w-full object-cover"
        />
      </div>

      <!-- Right: Copy -->
      <div>
        <p class="section-label">OUR VISION</p>
        <h2 class="section-title mt-3 mb-6">More Than a Place to Sleep</h2>
        <p class="text-stone text-lg leading-relaxed mb-6">
          We believe a great vacation rental should feel like a discovery, not a transaction.
          Every property at Whiskey Creek Beach is maintained with care, designed for comfort,
          and situated to make the most of this extraordinary landscape.
        </p>
        <p class="text-stone text-lg leading-relaxed">
          Whether you're watching the sunset from a beachfront cabin, reading by the fire in an
          A-frame, or falling asleep to the sound of the waves in a tent — you're part of this
          place, not just passing through.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════ 4. VALUES ═══════════════════ -->
  <section class="fade-section py-24 px-6 bg-white">
    <div class="max-w-7xl mx-auto text-center">
      <h2 class="font-display text-3xl font-bold text-midnight mb-16">What We Stand For</h2>

      <div class="grid md:grid-cols-3 gap-10">
        <!-- Stewardship -->
        <div class="text-center">
          <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-moss/10 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-moss" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.115 5.19l.319 1.913A6 6 0 008.11 10.36L9.75 12l-.387.775c-.217.433-.132.956.21 1.298l1.348 1.348c.21.21.329.497.329.795v1.089c0 .426.24.815.622 1.006l.153.076c.433.217.956.132 1.298-.21l.723-.723a8.7 8.7 0 002.288-4.042 1.087 1.087 0 00-.358-1.099l-1.33-1.108c-.251-.21-.582-.299-.905-.245l-1.17.195a1.125 1.125 0 01-.98-.314l-.295-.295a1.125 1.125 0 010-1.591l.13-.132a1.125 1.125 0 011.3-.21l.603.302a.809.809 0 001.086-1.086L14.25 7.5l1.256-.837a4.5 4.5 0 001.528-1.732l.146-.292M6.115 5.19A9 9 0 1017.18 4.64M6.115 5.19A8.965 8.965 0 0112 3c1.929 0 3.716.607 5.18 1.64" />
            </svg>
          </div>
          <h3 class="font-display text-xl font-bold text-midnight mb-3">Stewardship</h3>
          <p class="text-stone text-sm leading-relaxed max-w-xs mx-auto">
            We care for this land as if it were our own — because it is. Sustainable practices,
            local materials, and respect for the natural environment guide everything we do.
          </p>
        </div>

        <!-- Hospitality -->
        <div class="text-center">
          <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-moss/10 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-moss" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" />
            </svg>
          </div>
          <h3 class="font-display text-xl font-bold text-midnight mb-3">Hospitality</h3>
          <p class="text-stone text-sm leading-relaxed max-w-xs mx-auto">
            Every guest is treated like family. From the moment you book to the day you leave,
            we're here to make your stay effortless and memorable.
          </p>
        </div>

        <!-- Adventure -->
        <div class="text-center">
          <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-moss/10 flex items-center justify-center">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-moss" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 2L12 6M12 18L12 22M2 12L6 12M18 12L22 12M12 8a4 4 0 100 8 4 4 0 000-8z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 2l3 4h-6l3-4z" />
            </svg>
          </div>
          <h3 class="font-display text-xl font-bold text-midnight mb-3">Adventure</h3>
          <p class="text-stone text-sm leading-relaxed max-w-xs mx-auto">
            The Olympic Peninsula is one of the most stunning places on Earth. We'll help you
            make the most of it — from hiking trails to hidden beaches to the best local restaurants.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════ 5. THE LAND ═══════════════════ -->
  <section class="fade-section py-24 px-6 bg-midnight text-white">
    <div class="max-w-6xl mx-auto grid lg:grid-cols-2 gap-16 items-center">
      <!-- Left: Copy -->
      <div>
        <p class="section-label text-stone">THE LAND</p>
        <h2 class="font-display text-4xl font-bold text-white mt-3 mb-6">The Olympic Peninsula</h2>
        <p class="text-fog text-lg leading-relaxed">
          The northern coast of the Olympic Peninsula is unlike anywhere else in the lower 48.
          Ancient rainforests, alpine meadows, wild Pacific coastline, and the calm waters of the
          Strait of Juan de Fuca all converge here. Port Angeles sits at the heart of it, a small
          town with big access to some of the most dramatic landscapes in North America.
        </p>
      </div>

      <!-- Right: Photo -->
      <div>
        <img
          src="/images/about/map.jpg"
          alt="Map of the Olympic Peninsula"
          loading="lazy"
          decoding="async"
          class="rounded-lg shadow-xl aspect-[4/3] w-full object-cover"
        />
      </div>
    </div>
  </section>

  <!-- ═══════════════════ 6. CTA ═══════════════════ -->
  <section class="fade-section py-20 bg-copper/10">
    <div class="text-center max-w-2xl mx-auto px-6">
      <h2 class="font-display text-3xl font-bold text-midnight mb-4">Come see for yourself</h2>
      <p class="text-stone mb-8">
        Explore our properties and start planning your Pacific Northwest escape.
      </p>
      <a href="/properties" class="btn-primary">Browse Properties</a>
    </div>
  </section>

</BaseLayout>
